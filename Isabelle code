lemma PO24_GetHighestBid_satisfiable:
  assumes "pre_GetHighestBid s"
  shows "∃amount s'. post_GetHighestBid s amount"
proof -
  (* Extract value from currentBid *)
  obtain amt where
    "currentBid s = Some amt"
    using assms
    unfolding pre_GetHighestBid_def
    by (cases "currentBid s") auto

  (* Choose result and state *)
  let ?amount = amt
  let ?s' = s   (* no state change *)

  (* Show postcondition *)
  have "post_GetHighestBid s ?amount"
    unfolding post_GetHighestBid_def
    using `currentBid s = Some amt`
    by simp

  thus ?thesis
    by blast
qed

lemma PO26_GetStatus_satisfiable:
  shows "∃st. post_GetStatus s st"
proof -
  let ?st = "status s"

  have "post_GetStatus s ?st"
    unfolding post_GetStatus_def
    by simp

  thus ?thesis
    by blast
qed

